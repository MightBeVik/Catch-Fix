PORT=3001
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_compatible_api_key_here
DATABASE_PATH=./data/catch_fix.db
DEMO_SEED_DATA=true
DRIFT_THRESHOLD=70
EVALUATION_CRON=*/30 * * * *
ANTHROPIC_TIMEOUT_MS=15000
ANTHROPIC_MAX_RETRIES=2
OPENAI_MODEL=gpt-4.1-mini
OPENAI_ENDPOINT=https://api.openai.com/v1/chat/completions
OLLAMA_MODEL=llama3.2
OLLAMA_ENDPOINT=http://127.0.0.1:11434/api/generate

# Auth — generate a strong random secret for production
JWT_SECRET=change-me-to-a-long-random-string
# Password for the default admin account created on first run
ADMIN_PASSWORD=ChangeMe123!

# SMTP password reset email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM_EMAIL=your-gmail-address@gmail.com
SMTP_FROM_NAME=OverWatch
PASSWORD_RESET_BASE_URL=http://127.0.0.1:5174
APP_BASE_URL=http://127.0.0.1:5174
